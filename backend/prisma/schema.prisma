generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  phone        String?
  role         UserRole  @default(USER)
  refreshToken String?
  lastLogin    DateTime?
  isActive     Boolean   @default(true)
  isVerified Boolean @default(false)
  verificationCode String?
  passwordResetCode String?
  passwordResetExpires DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  addresses    Address[]
  orders       Order[]
}

model Address {
  id           String   @id @default(uuid())
  title        String
  city         String
  district     String
  neighborhood String
  street       String
  buildingNo   String
  floor        String?
  apartmentNo  String?
  directions   String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
}

model Category {
  id          String       @id @default(uuid())
  brand       Brand
  name        String
  slug        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orderIndex  Int          @default(0)
  products    Product[]
  traitGroups TraitGroup[] @relation("CategoryToTraitGroup")

  @@unique([brand, slug])
}

model TraitGroup {
  id         String     @id @default(uuid())
  brand      Brand
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  orderIndex Int        @default(0)
  traits     Trait[]
  categories Category[] @relation("CategoryToTraitGroup")
}

model Trait {
  id           String         @id @default(uuid())
  name         String
  traitGroupId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  products     ProductTrait[]
  traitGroup   TraitGroup     @relation(fields: [traitGroupId], references: [id], onDelete: Cascade)
}

model Product {
  id          String              @id @default(uuid())
  brand       Brand
  name        String
  description String?
  price       Decimal             @db.Decimal(10, 2)
  image       String?
  status      ProductStatus       @default(ACTIVE)
  categoryId  String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  orderItems  OrderItem[]
  category    Category            @relation(fields: [categoryId], references: [id])
  ingredients ProductIngredient[]
  traits      ProductTrait[]
}

model ProductTrait {
  productId String
  traitId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  trait     Trait   @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@id([productId, traitId])
}

model Ingredient {
  id           String                @id @default(uuid())
  brand        Brand
  name         String
  price        Decimal               @db.Decimal(10, 2)
  isStock      Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  categoryId   String?
  category     IngredientCategory?   @relation(fields: [categoryId], references: [id])
  orderItems   OrderItemIngredient[]
  products     ProductIngredient[]
  steps        StepIngredient[]
}

model IngredientCategory {
  id          String           @id @default(uuid())
  brand       Brand
  name        String
  orderIndex  Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  ingredients Ingredient[]
  steps       IngredientStep[]
}

model ProductIngredient {
  productId    String
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, ingredientId])
}

model IngredientStep {
  id          String              @id @default(uuid())
  brand       Brand
  name        String
  orderIndex  Int                 @default(0)
  isRequired  Boolean             @default(false)
  minSelect   Int                 @default(0)
  maxSelect   Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  categoryId  String?
  category    IngredientCategory? @relation(fields: [categoryId], references: [id])
  ingredients StepIngredient[]
}

model StepIngredient {
  stepId       String
  ingredientId String
  ingredient   Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  step         IngredientStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@id([stepId, ingredientId])
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   Int           @unique @default(autoincrement())
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        OrderStatus   @default(PENDING)
  paymentType   PaymentType
  paymentStatus PaymentStatus @default(PENDING)
  userId        String
  addressId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  address       Address       @relation(fields: [addressId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  subOrders     SubOrder[]
  transactions  Transaction[]
}

model SubOrder {
  id          String      @id @default(uuid())
  brand       Brand
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  orderId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id                  String                @id @default(uuid())
  quantity            Int                   @default(1)
  priceAtTime         Decimal               @db.Decimal(10, 2)
  subOrderId          String
  isCustom            Boolean               @default(false)
  productId           String?
  removedIngredients  Json?                 // List of ingredient IDs removed from recipe
  product             Product?              @relation(fields: [productId], references: [id])
  subOrder            SubOrder              @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  selectedIngredients OrderItemIngredient[]
}

model OrderItemIngredient {
  id           String     @id @default(uuid())
  priceAtTime  Decimal    @db.Decimal(10, 2)
  quantity     Int        @default(1)
  orderItemId  String
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  orderItem    OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model Transaction {
  id         String        @id @default(uuid())
  amount     Decimal       @db.Decimal(10, 2)
  provider   String
  externalId String?
  status     PaymentStatus
  orderId    String
  createdAt  DateTime      @default(now())
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OperationCalendar {
  id        String   @id @default(uuid())
  title     String
  date      DateTime
  type      String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Brand {
  DYSALATTO
  DYCAKE
}

enum UserRole {
  ADMIN
  USER
  GUEST
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  HIDDEN
}

enum OrderStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentType {
  ONLINE
  CASH_AT_DOOR
  CARD_AT_DOOR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
